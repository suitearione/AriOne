# =============================================================================
# Variáveis de Ambiente - AriOne ERP
# =============================================================================
# Copie este arquivo para .env e preencha com seus valores reais

# Ambiente
FLASK_ENV=production
FLASK_DEBUG=0

# Segurança
SECRET_KEY=chave-secreta-aqui-trocar-em-producao

# Banco de Dados
# Para desenvolvimento (SQLite):
# DATABASE_URL=sqlite:///instance/arione.db

# Para produção (PostgreSQL):
DATABASE_URL=postgresql://usuario:senha@host:porta/nome_banco

# Servidor
FLASK_PORT=5000
FLASK_HOST=0.0.0.0

# AWS S3 (opcional - para armazenamento de arquivos)
AWS_ACCESS_KEY_ID=sua_chave_aws
AWS_SECRET_ACCESS_KEY=seu_secreto_aws
AWS_REGION=us-east-1
S3_BUCKET=nome-do-bucket

# Redis (opcional - para cache e filas)
REDIS_URL=redis://localhost:6379/0

# Email (opcional - para envio de emails)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=seu_email@gmail.com
MAIL_PASSWORD=sua_senha_app

# Logs
LOG_LEVEL=INFO
LOG_FILE=logs/arione.log
